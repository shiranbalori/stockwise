# =============================================================================
# StockWise — Environment Variables
# =============================================================================
# Copy this file to .env for local development:
#   cp .env.example .env
#
# For production (Vercel, Netlify, Firebase Hosting, etc.):
#   Set these variables in your hosting provider's dashboard BEFORE running build.
#   Vite embeds VITE_* variables into the client bundle at build time.
#
# NEVER commit .env or real secrets to GitHub.
# =============================================================================

# --- Firebase (required for cloud sync) ---
# Firebase Console → Project Settings → Your apps → Web app
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# --- Finnhub Stock API (required for live market data) ---
# Get a free key at: https://finnhub.io/
# Note: the API key is included in the client bundle. Restrict by domain in Finnhub dashboard.
VITE_STOCK_API_KEY=your_stock_api_key_here
VITE_STOCK_API_BASE_URL=https://finnhub.io/api/v1
